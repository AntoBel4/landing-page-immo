    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst data = items[0].json.data || [];\n\nconst stats = {\n  total_envoyes: data.length,\n  premiere_execution: data[0]?.date_envoi || null,\n  derniere_execution: data[data.length - 1]?.date_envoi || null,\n  duree_totale_minutes: data.length > 0 ? \n    Math.round((new Date(data[data.length - 1].date_envoi) - new Date(data[0].date_envoi)) / 60000) : 0,\n  timestamp_fin: new Date().toISOString(),\n  status: 'SUCCESS'\n};\n\nreturn [{ json: stats }];"
      },
